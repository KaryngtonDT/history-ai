# History AI — Environment Variables
# Copy to .env and adjust values for local development.

# --- Application ---
APP_ENV=dev
APP_SECRET=change-me

# --- Backend (Symfony) ---
DATABASE_URL=postgresql://history_ai:history_ai@postgres:5432/history_ai?serverVersion=17&charset=utf8
MESSENGER_TRANSPORT_DSN=redis://redis:6379/messages

# --- Frontend ---
VITE_API_URL=http://localhost:8000

# --- Worker ---
WORKER_API_URL=http://backend:8080

# --- PostgreSQL ---
POSTGRES_DB=history_ai
POSTGRES_USER=history_ai
POSTGRES_PASSWORD=history_ai
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PORT=6379

# --- MinIO (S3-compatible) ---
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio_password
MINIO_BUCKET=history-ai
MINIO_ENDPOINT=http://minio:9000
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
AWS_ACCESS_KEY_ID=minio
AWS_SECRET_ACCESS_KEY=minio_password
AWS_REGION=us-east-1
S3_BUCKET=history-ai

# --- AI ---
GEMINI_API_KEY=
SUMMARY_GENERATOR=deterministic
AI_PROVIDER=mock
AI_EXECUTION_MODE=balanced
OPENAI_API_KEY=

# --- AI pipeline engines (defaults must match Runtime Center /settings/runtime) ---
STT_PROVIDER=faster_whisper
STT_FASTER_WHISPER_MODEL=large-v3
TRANSLATION_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=gemma3:4b
OLLAMA_PORT=11434
TTS_PROVIDER=f5
VOICE_CLONE_PROVIDER=openvoice
LIP_SYNC_PROVIDER=latentsync
VIDEO_RENDER_PROVIDER=ffmpeg
# Alternative engines (install on host or mount under MODELS_ROOT — see docs/operations/ENGINE_INSTALLATION.md)
# STT alternatives: parakeet, canary
# Translation alternatives: pull `ollama pull qwen3:4b` or `ollama pull deepseek-r1:1.5b`
# TTS alternatives: kokoro, dia
# Voice clone alternatives: chatterbox, xtts
# Lip sync alternatives: echomimic, musetalk
# Render alternatives: set VIDEO_RENDER_PROVIDER=ffmpeg_nvenc or ffmpeg_av1 (requires encoder support)

# --- Storage & Models (Sprint 59) ---
MODELS_ROOT=/models
COMPOSE_FILE=docker-compose.prod-like.yml
