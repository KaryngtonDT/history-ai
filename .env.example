# History AI — Environment Variables
# Copy to .env and adjust values for local development.

# --- Application ---
APP_ENV=dev
APP_SECRET=change-me

# --- Backend (Symfony) ---
DATABASE_URL=postgresql://history_ai:history_ai@postgres:5432/history_ai?serverVersion=17&charset=utf8
MESSENGER_TRANSPORT_DSN=redis://redis:6379/messages

# --- Frontend ---
VITE_API_URL=http://localhost:8000

# --- Worker ---
WORKER_API_URL=http://backend:8080

# --- PostgreSQL ---
POSTGRES_DB=history_ai
POSTGRES_USER=history_ai
POSTGRES_PASSWORD=history_ai
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PORT=6379

# --- MinIO (S3-compatible) ---
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio_password
MINIO_BUCKET=history-ai
MINIO_ENDPOINT=http://minio:9000
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
AWS_ACCESS_KEY_ID=minio
AWS_SECRET_ACCESS_KEY=minio_password
AWS_REGION=us-east-1
S3_BUCKET=history-ai

# --- AI ---
GEMINI_API_KEY=
AI_PROVIDER=mock
AI_EXECUTION_MODE=balanced
OPENAI_API_KEY=
