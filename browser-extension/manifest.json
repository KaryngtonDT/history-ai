{
  "manifest_version": 3,
  "name": "HistoryAI Shadow Browser",
  "version": "0.1.0",
  "description": "Shadow Browser extension for HistoryAI / Lumen — contextual explain, translate, and save.",
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "HistoryAI Shadow",
    "default_popup": "popup/popup.html"
  },
  "options_page": "options/options.html",
  "permissions": ["storage", "activeTab", "tabs"],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*",
    "https://*/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/detector.js", "content/overlay.js"],
      "run_at": "document_idle"
    }
  ]
}
