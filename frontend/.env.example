# Mock repository — true for local UI dev; false to hit Symfony API
VITE_USE_MOCK=true

# Symfony API base URL (browser → backend)
VITE_API_BASE_URL=http://localhost:8000

# Docker Compose dev override mounts ./frontend and runs Vite (see docker-compose.override.yml).
# Production-like preview in docker-compose.yml uses VITE_USE_MOCK=false at build time.
