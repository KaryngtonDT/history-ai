#!/bin/bash
set -euo pipefail
VENV_PYTHON="/models/venvs/openvoice/bin/python"
RUNNER="/opt/lumen/engines/openvoice_runner.py"
if [[ -x "${VENV_PYTHON}" && -f "${RUNNER}" && -d "/models/openvoice/checkpoints_v2" ]]; then
  exec "${VENV_PYTHON}" "${RUNNER}" "$@"
fi
exec /opt/lumen/placeholders/openvoice "$@"
