#!/bin/bash
set -euo pipefail
VENV_PYTHON="/models/venvs/latentsync/bin/python"
RUNNER="/opt/lumen/engines/latentsync_runner.py"
if [[ -x "${VENV_PYTHON}" && -f "${RUNNER}" && -f "/models/latentsync/checkpoints/latentsync_unet.pt" ]]; then
  export LATENTSYNC_SRC="/models/src/LatentSync"
  exec "${VENV_PYTHON}" "${RUNNER}" "$@"
fi
exec /opt/lumen/placeholders/latentsync "$@"
