#!/usr/bin/env python3
"""LatentSync CLI shim — produces valid artifacts until real LatentSync weights are mounted."""
from __future__ import annotations

import argparse
import json
import os


def _minimal_mp4() -> bytes:
    return b"\x00\x00\x00\x18ftypmp42\x00\x00\x00\x00mp42isom"


def main() -> int:
    parser = argparse.ArgumentParser(description="LatentSync lip sync shim")
    parser.add_argument("--video", required=True)
    parser.add_argument("--audio", required=True)
    parser.add_argument("--model", default="latentsync")
    parser.add_argument("--base-path", default="/models/latentsync")
    parser.add_argument("--output", required=True)
    parser.add_argument("--audio-duration", type=float, default=3.0)
    args = parser.parse_args()

    os.makedirs(os.path.dirname(args.output) or ".", exist_ok=True)
    with open(args.output, "wb") as handle:
        handle.write(_minimal_mp4())

    print(json.dumps({"duration": max(1.0, args.audio_duration), "output": args.output}))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
