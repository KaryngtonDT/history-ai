#!/usr/bin/env python3
"""Lumen BGE-M3 embeddings wrapper (FlagEmbedding, CPU-compatible)."""
from __future__ import annotations

import argparse
import json
import os
import sys


def main() -> int:
    if "--version" in sys.argv or "-version" in sys.argv:
        try:
            import FlagEmbedding  # type: ignore[import]
            print(f"bge-m3 (FlagEmbedding {getattr(FlagEmbedding, '__version__', 'installed')})")
        except ImportError:
            print("bge-m3 (not installed — run: make provision ENGINE=bge_m3)")
        return 0

    parser = argparse.ArgumentParser(description="Lumen BGE-M3 text embeddings")
    parser.add_argument("--texts", nargs="+", required=True)
    parser.add_argument("--base-path", default="/models/bge-m3")
    parser.add_argument("--batch-size", type=int, default=12)
    args = parser.parse_args()

    try:
        from FlagEmbedding import BGEM3FlagModel  # type: ignore[import]
    except ImportError:
        print("FlagEmbedding not installed. Run: make provision ENGINE=bge_m3", file=sys.stderr)
        return 1

    if not os.path.isdir(args.base_path) or not any(
        f for f in os.listdir(args.base_path) if not f.startswith(".")
    ):
        print(f"BGE-M3 model not found at {args.base_path}. Run: make provision ENGINE=bge_m3", file=sys.stderr)
        return 1

    try:
        model = BGEM3FlagModel(args.base_path, use_fp16=False)
        output = model.encode(args.texts, batch_size=args.batch_size, max_length=512)
        embeddings = output["dense_vecs"].tolist()
        result = {"embeddings": embeddings, "model": "bge-m3", "dim": len(embeddings[0]) if embeddings else 0}
        print(json.dumps(result))
        return 0
    except Exception as exc:  # noqa: BLE001
        print(str(exc), file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
