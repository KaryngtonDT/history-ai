#!/usr/bin/env python3
"""Lumen Jina Reranker wrapper (sentence-transformers CrossEncoder, CPU-compatible)."""
from __future__ import annotations

import argparse
import json
import os
import sys


def main() -> int:
    if "--version" in sys.argv or "-version" in sys.argv:
        try:
            import sentence_transformers  # type: ignore[import]
            print(f"jina-reranker (sentence-transformers {sentence_transformers.__version__})")
        except ImportError:
            print("jina-reranker (not installed — run: make provision ENGINE=jina_reranker)")
        return 0

    parser = argparse.ArgumentParser(description="Lumen Jina Reranker")
    parser.add_argument("--query", required=True)
    parser.add_argument("--docs", nargs="+", required=True)
    parser.add_argument("--base-path", default="/models/jina-reranker")
    args = parser.parse_args()

    try:
        from sentence_transformers import CrossEncoder  # type: ignore[import]
    except ImportError:
        print("sentence-transformers not installed. Run: make provision ENGINE=jina_reranker", file=sys.stderr)
        return 1

    if not os.path.isdir(args.base_path) or not any(
        f for f in os.listdir(args.base_path) if not f.startswith(".")
    ):
        print(f"Jina Reranker model not found at {args.base_path}. Run: make provision ENGINE=jina_reranker", file=sys.stderr)
        return 1

    try:
        model = CrossEncoder(args.base_path)
        pairs = [[args.query, doc] for doc in args.docs]
        scores = model.predict(pairs).tolist()
        ranked = sorted(
            [{"doc": doc, "score": float(s)} for doc, s in zip(args.docs, scores)],
            key=lambda x: x["score"],
            reverse=True,
        )
        result = {"ranked": ranked, "model": "jina-reranker"}
        print(json.dumps(result))
        return 0
    except Exception as exc:  # noqa: BLE001
        print(str(exc), file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
