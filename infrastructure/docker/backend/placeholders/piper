#!/usr/bin/env python3
"""Piper TTS CLI placeholder."""
import argparse
import sys


def main() -> int:
    parser = argparse.ArgumentParser(description="Piper placeholder")
    parser.add_argument("--model", required=False)
    parser.add_argument("--output_file", required=False)
    args = parser.parse_args()

    if "--version" in sys.argv:
        print("piper placeholder 0.0.0")
        return 0

    if args.output_file:
        with open(args.output_file, "wb") as handle:
            handle.write(b"RIFF\x24\x00\x00\x00WAVEfmt ")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
